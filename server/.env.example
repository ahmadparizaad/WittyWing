# Server
PORT=3000
SESSION_SECRET=change-me
MONGO_URI=mongodb://localhost:27017/twitter-automation

# Google OAuth credentials (for PoC)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Gemini API Keys (optional, comma-separated). If you provide multiple keys the server will rotate/backup on rate limits.
# Example: GEMINI_API_KEYS=AIzaSy...,AIzaSy...,AIzaSy...
GEMINI_API_KEYS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash:generateContent
